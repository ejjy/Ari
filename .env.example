# Copy this file to .env and fill in your values
# Expo reads EXPO_PUBLIC_* variables at build time

# Your deployed Flask backend URL (no trailing slash)
# Example: https://api.yourserver.com/api
EXPO_PUBLIC_API_URL=https://your-backend-url.com/api

# Sentry DSN for crash reporting (get from sentry.io)
EXPO_PUBLIC_SENTRY_DSN=

# Supabase — dedicated Ari project. Anon key is public (shipped in the
# bundle). Get both from Settings -> API in the Supabase dashboard.
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# PostHog — Day-1/7/30 retention tracking (spec §2). Project API key,
# safe to ship in the bundle. Leave unset to no-op analytics.
EXPO_PUBLIC_POSTHOG_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google OAuth — Android client id from Google Cloud Console.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
