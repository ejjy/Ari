*-service-account*.json
*serviceAccount*.json
firebase-adminsdk-*.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
scripts/__pycache__/

# Supabase CLI temp files
supabase/.temp/

# Claude / agent local settings
.claude/

# Logs
*.log

# Signing credentials — NEVER commit
*.jks
*.keystore
credentials.json
*.p12
*.pem
