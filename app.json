{
  "expo": {
    "name": "Ari",
    "slug": "ari",
    "owner": "pinegrass-tech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ari.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.ari.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0A",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "pinegrass",
          "project": "ari"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Ari needs your microphone to log expenses by voice.",
          "speechRecognitionPermission": "Ari needs speech recognition to turn your voice into transactions."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/ae18eabf-124f-4b0a-a09e-a2a40dfb473b"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "ae18eabf-124f-4b0a-a09e-a2a40dfb473b"
      }
    }
  }
}
